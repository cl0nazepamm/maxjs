    CONTROL         "",  IDC_BUMP_MAP,   "CustButton", WS_TABSTOP, 24,282, 38, 12
    LTEXT           "Scale",     -1,  66,284, 18,  8
    CONTROL         "",  IDC_BUMP_EDIT,  "CustEdit",   WS_TABSTOP, 84,282, 10, 10
    CONTROL         "",  IDC_BUMP_SPIN,  "SpinnerControl",0,       94,282,  7, 10
    LTEXT           "Disp",      -1,   6,296, 18,  8
    CONTROL         "",  IDC_DISP_MAP,   "CustButton", WS_TABSTOP, 24,294, 38, 12
    LTEXT           "S",         -1,  66,296,  6,  8
    CONTROL         "",  IDC_DISP_EDIT,  "CustEdit",   WS_TABSTOP, 72,294, 10, 10
    CONTROL         "",  IDC_DISP_SPIN,  "SpinnerControl",0,       82,294,  7, 10
    LTEXT           "B",         -1,  90,296,  6,  8
    CONTROL         "",  IDC_DISP_BIAS_EDIT,"CustEdit",WS_TABSTOP, 96,294,  8, 10
    CONTROL         "",  IDC_DISP_BIAS_SPIN,"SpinnerControl",0,    104,294,  4, 10

    // ── Options ───────────────────────────────
    GROUPBOX        "Options",   -1,   2,328,104, 30
    CONTROL         "Double Sided",IDC_DOUBLE_SIDED,"Button",BS_AUTOCHECKBOX|WS_TABSTOP, 6,340, 56, 10
    LTEXT           "Env",       -1,  64,340, 14,  8
    CONTROL         "",  IDC_ENV_INT_EDIT,"CustEdit",  WS_TABSTOP, 78,338, 16, 10
    CONTROL         "",  IDC_ENV_INT_SPIN,"SpinnerControl",0,      94,338,  7, 10

    // ── Bottom padding ────────────────────────
