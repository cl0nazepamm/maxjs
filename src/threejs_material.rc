#include "resource.h"
#include <windows.h>

STRINGTABLE
BEGIN
    IDS_PARAMS "ThreeJS Material"
END

IDD_THREEJS_MTL DIALOG 0, 0, 108, 378
STYLE DS_SETFONT | WS_CHILD | WS_VISIBLE
FONT 8, "MS Sans Serif"
BEGIN
    // ── PBR Core ──────────────────────────────
    LTEXT           "Color",     -1,   4,  4, 36,  8
    CONTROL         "",  IDC_COLOR,    "ColorSwatch",  WS_TABSTOP, 42,  2, 40, 12
    CONTROL         "",  IDC_COLOR_MAP,"CustButton",   WS_TABSTOP, 86,  2, 18, 12
    LTEXT           "Map Amt",   -1,   4, 14, 36,  8
    CONTROL         "",  IDC_MAPSTR_EDIT,"CustEdit",   WS_TABSTOP, 42, 12, 36, 10
    CONTROL         "",  IDC_MAPSTR_SPIN,"SpinnerControl",0,       78, 12,  7, 10

    LTEXT           "Roughness", -1,   4, 30, 36,  8
    CONTROL         "",  IDC_ROUGH_EDIT,"CustEdit",    WS_TABSTOP, 42, 28, 36, 10
    CONTROL         "",  IDC_ROUGH_SPIN,"SpinnerControl",0,        78, 28,  7, 10
    CONTROL         "",  IDC_ROUGH_MAP, "CustButton",  WS_TABSTOP, 86, 28, 18, 10
    LTEXT           "Rough Amt", -1,   4, 42, 36,  8
    CONTROL         "",  IDC_RMAPSTR_EDIT,"CustEdit",  WS_TABSTOP, 42, 40, 36, 10
    CONTROL         "",  IDC_RMAPSTR_SPIN,"SpinnerControl",0,      78, 40,  7, 10

    LTEXT           "Metalness", -1,   4, 54, 36,  8
