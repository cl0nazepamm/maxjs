    LTEXT           "Int",       -1,  58,252, 12,  8
    CONTROL         "",  IDC_AO_INT_EDIT,"CustEdit",   WS_TABSTOP, 72,250, 22, 10
    CONTROL         "",  IDC_AO_INT_SPIN,"SpinnerControl",0,       94,250,  7, 10

    // ── Surface Detail ────────────────────────
    GROUPBOX        "Surface Detail",-1, 2,272,104, 54
