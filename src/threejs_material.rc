    LTEXT           "Metal Amt", -1,   4, 66, 36,  8
    CONTROL         "",  IDC_MMAPSTR_EDIT,"CustEdit",  WS_TABSTOP, 42, 64, 36, 10
    CONTROL         "",  IDC_MMAPSTR_SPIN,"SpinnerControl",0,      78, 64,  7, 10

    LTEXT           "Normal Map",-1,   4, 78, 36,  8
    CONTROL         "",  IDC_NORMAL_MAP,"CustButton",  WS_TABSTOP, 42, 76, 62, 10
