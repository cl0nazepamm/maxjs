    CONTROL         "",  IDC_NORMSCL_EDIT,"CustEdit",  WS_TABSTOP, 48, 88, 30, 10
    CONTROL         "",  IDC_NORMSCL_SPIN,"SpinnerControl",0,      78, 88,  7, 10

    LTEXT           "Opacity",   -1,   4,102, 36,  8
    CONTROL         "",  IDC_OPACITY_EDIT,"CustEdit",  WS_TABSTOP, 42,100, 36, 10
    CONTROL         "",  IDC_OPACITY_SPIN,"SpinnerControl",0,      78,100,  7, 10
    CONTROL         "",  IDC_OPACITY_MAP, "CustButton",WS_TABSTOP, 86,100, 18, 10
    LTEXT           "Alpha Amt", -1,   4,114, 36,  8
    CONTROL         "",  IDC_OPMAPSTR_EDIT,"CustEdit", WS_TABSTOP, 42,112, 36, 10
    CONTROL         "",  IDC_OPMAPSTR_SPIN,"SpinnerControl",0,     78,112,  7, 10

    // ── Emission ──────────────────────────────
    GROUPBOX        "Emission",  -1,   2,126,104, 54
    LTEXT           "Color",     -1,   6,138, 24,  8
    CONTROL         "",  IDC_EM_COLOR,  "ColorSwatch", WS_TABSTOP, 32,136, 30, 12
    CONTROL         "",  IDC_EM_MAP,    "CustButton",  WS_TABSTOP, 64,136, 38, 12
    LTEXT           "Intensity", -1,   6,152, 36,  8
    CONTROL         "",  IDC_EM_INT_EDIT,"CustEdit",   WS_TABSTOP, 42,150, 36, 10
    CONTROL         "",  IDC_EM_INT_SPIN,"SpinnerControl",0,       78,150,  7, 10
    LTEXT           "Map Amt",   -1,   6,164, 36,  8
    CONTROL         "",  IDC_EMMAPSTR_EDIT,"CustEdit", WS_TABSTOP, 42,162, 36, 10
    CONTROL         "",  IDC_EMMAPSTR_SPIN,"SpinnerControl",0,     78,162,  7, 10

    // ── Lightmap ──────────────────────────────
    GROUPBOX        "Lightmap",  -1,   2,184,104, 54
    LTEXT           "Map",       -1,   6,196, 24,  8
    CONTROL         "",  IDC_LM_MAP,    "CustButton",  WS_TABSTOP, 32,194, 70, 12
    LTEXT           "Intensity", -1,   6,210, 36,  8
    CONTROL         "",  IDC_LM_INT_EDIT,"CustEdit",   WS_TABSTOP, 42,208, 36, 10
    CONTROL         "",  IDC_LM_INT_SPIN,"SpinnerControl",0,       78,208,  7, 10
