#include "threejs_splat_res.h"
#include <windows.h>

STRINGTABLE
BEGIN
    IDS_SPLAT_PARAMS "Splat Origin"
    IDS_SPLAT_DISPLAY_SIZE "Display Size"
    IDS_SPLAT_FILE "Splat File"
END

IDD_THREEJS_SPLAT DIALOG 0, 0, 170, 40
STYLE DS_SETFONT | WS_CHILD | WS_VISIBLE
FONT 8, "Segoe UI"
BEGIN
    LTEXT           "File", -1, 8, 6, 160, 8
    EDITTEXT        IDC_SPLAT_PATH, 24, 4, 96, 12, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "Load...", IDC_SPLAT_LOAD, 124, 4, 40, 12
    PUSHBUTTON      "Clear", IDC_SPLAT_CLEAR, 124, 20, 40, 12
    
    LTEXT           "Display", -1, 8, 20, 42, 8
    CONTROL         "", IDC_SPLAT_SIZE_EDIT, "CustEdit", WS_TABSTOP, 52, 18, 30, 10
    CONTROL         "", IDC_SPLAT_SIZE_SPIN, "SpinnerControl", 0, 82, 18, 11, 10
END
