#include "threejs_toon_res.h"
#include <windows.h>

STRINGTABLE
BEGIN
    IDS_TOON_PARAMS "ThreeJS Toon"
END

IDD_THREEJS_TOON DIALOG 0, 0, 170, 310
STYLE DS_SETFONT | WS_CHILD | WS_VISIBLE
FONT 8, "Segoe UI"
BEGIN
    // ── Color ─────────────────────────────────
    LTEXT           "Color",     -1,   4,  4, 22,  8
    CONTROL         "",  IDC_TOON_COLOR,    "ColorSwatch",    WS_TABSTOP, 28,  2, 30, 12
    CONTROL         "",  IDC_TOON_COLOR_MAP,"CustButton",     WS_TABSTOP, 60,  2, 44, 12

    // ── Gradient Map (key toon feature) ───────
    LTEXT           "Gradient",  -1,   4, 18, 30,  8
    CONTROL         "",  IDC_TOON_GRAD_MAP, "CustButton",     WS_TABSTOP, 36, 16, 68, 12

    // ── Normal ────────────────────────────────
    LTEXT           "Normal",    -1,   4, 34, 24,  8
    CONTROL         "",  IDC_TOON_NORM_MAP, "CustButton",     WS_TABSTOP, 30, 32, 44, 10
    LTEXT           "Scl",       -1,  76, 34, 12,  8
    CONTROL         "",  IDC_TOON_NORMSCL_E,"CustEdit", WS_TABSTOP, 88, 32, 40, 10
    CONTROL         "",  IDC_TOON_NORMSCL_S,"SpinnerControl",  0,        100, 32,  7, 10

    // ── Bump ──────────────────────────────────
    LTEXT           "Bump",      -1,   4, 48, 22,  8
    CONTROL         "",  IDC_TOON_BUMP_MAP, "CustButton",     WS_TABSTOP, 30, 46, 44, 10
    LTEXT           "Scl",       -1,  76, 48, 12,  8
    CONTROL         "",  IDC_TOON_BUMP_E,   "CustEdit", WS_TABSTOP, 88, 46, 40, 10
    CONTROL         "",  IDC_TOON_BUMP_S,   "SpinnerControl",  0,        100, 46,  7, 10

    // ── Opacity ───────────────────────────────
    LTEXT           "Opacity",   -1,   4, 62, 28,  8
    CONTROL         "",  IDC_TOON_OPAC_E,   "CustEdit", WS_TABSTOP, 34, 60, 40, 10
    CONTROL         "",  IDC_TOON_OPAC_S,   "SpinnerControl",  0,         52, 60,  7, 10
    CONTROL         "",  IDC_TOON_OPAC_MAP, "CustButton",     WS_TABSTOP, 60, 60, 44, 10

    // ── Emission ──────────────────────────────
    GROUPBOX        "Emission",  -1,   2, 76,104, 42
    LTEXT           "Color",     -1,   6, 88, 20,  8
    CONTROL         "",  IDC_TOON_EM_COLOR, "ColorSwatch",    WS_TABSTOP, 28, 86, 30, 12
    CONTROL         "",  IDC_TOON_EM_MAP,   "CustButton",     WS_TABSTOP, 60, 86, 42, 12
    LTEXT           "Int",       -1,   6,102, 12,  8
    CONTROL         "",  IDC_TOON_EM_INT_E, "CustEdit", WS_TABSTOP, 20, 100, 40, 10
    CONTROL         "",  IDC_TOON_EM_INT_S, "SpinnerControl",  0,         44,100,  7, 10

    // ── Lightmap ──────────────────────────────
    GROUPBOX        "Lightmap",  -1,   2,122,104, 42
    LTEXT           "Map",       -1,   6,134, 16,  8
    CONTROL         "",  IDC_TOON_LM_MAP,   "CustButton",     WS_TABSTOP, 24,132, 78, 12
    LTEXT           "Int",       -1,   6,148, 12,  8
    CONTROL         "",  IDC_TOON_LM_INT_E, "CustEdit", WS_TABSTOP, 20, 146, 40, 10
    CONTROL         "",  IDC_TOON_LM_INT_S, "SpinnerControl",  0,         44,146,  7, 10
    LTEXT           "UV",        -1,  56,148, 12,  8
    CONTROL         "",  IDC_TOON_LM_CH_E,  "CustEdit", WS_TABSTOP, 70, 146, 40, 10
    CONTROL         "",  IDC_TOON_LM_CH_S,  "SpinnerControl",  0,         86,146,  7, 10

    // ── AO ────────────────────────────────────
    GROUPBOX        "AO",        -1,   2,168,104, 28
    CONTROL         "",  IDC_TOON_AO_MAP,   "CustButton",     WS_TABSTOP,  6,180, 44, 12
    LTEXT           "Int",       -1,  54,182, 12,  8
    CONTROL         "",  IDC_TOON_AO_INT_E, "CustEdit", WS_TABSTOP, 68, 180, 40, 10
    CONTROL         "",  IDC_TOON_AO_INT_S, "SpinnerControl",  0,         90,180,  7, 10

    // ── Displacement ──────────────────────────
    GROUPBOX        "Displacement",-1, 2,200,104, 42
    CONTROL         "",  IDC_TOON_DISP_MAP, "CustButton",     WS_TABSTOP,  6,212, 44, 12
    LTEXT           "Scl",       -1,  54,214, 12,  8
    CONTROL         "",  IDC_TOON_DISP_E,   "CustEdit", WS_TABSTOP, 68, 212, 40, 10
    CONTROL         "",  IDC_TOON_DISP_S,   "SpinnerControl",  0,         90,212,  7, 10
    LTEXT           "Bias",      -1,   6,228, 16,  8
    CONTROL         "",  IDC_TOON_DISP_B_E, "CustEdit", WS_TABSTOP, 24, 226, 40, 10
    CONTROL         "",  IDC_TOON_DISP_B_S, "SpinnerControl",  0,         48,226,  7, 10

    // ── Options ───────────────────────────────
    CONTROL         "Double Sided",IDC_TOON_DBLSIDE,"Button",BS_AUTOCHECKBOX|WS_TABSTOP, 4,248, 56, 10
    LTEXT           "Model: MeshToonMaterial", -1, 4, 262, 96, 8

    LTEXT           "",  -1,   0,300,  0,  0
END
