// Pollen from all listed bee meshes — drops with gravity + turbulence; can stick to `flowercenter` mesh (raycast).
// Emitter keeps spawning into free slots forever (no overwrite of living particles).
//
// Uses camera-facing instanced quads instead of THREE.Points so particle size
// behaves consistently under the WebGPU renderer.

const PARTICLE_COUNT = 32000;
const SPAWN_PER_FRAME = 2;
const HIDDEN_SCALE = 0.0001;
const LIFE_SECONDS = 4.2;
const FADE_IN_SEC = 0.18;
const FADE_OUT_START = 0.68;
const NORMAL_FOLLOW = 4.2;
const NORM_RESAMPLE_STRIDE = 256;
const WORLD_GRAVITY = 25.35;
const LIFT_ALONG_BEE_N = 0.12;
const TURBULENCE = 0.55;
const STICK_STRIDE = 640;
const STICK_SNAP_STRIDE = 8;
const STICK_RAY_UP = 2.5;
const STICK_RAY_FAR = 28;
const STICK_SURFACE_EPS = 0.0012;
const STICK_NORMAL_PROBE = 0.35;
const STICK_APPROACH_FAR = 1.2;
const STICK_SLIDE_GRAV = 0.85;
const STICK_DRAG = 0.94;
const STICK_TRY_VY = 0.35;

// Max node names — every match in the scene emits (each particle sticks to its bee).
const EMITTER_SOURCES = ['Bee', 'Bee001'];

// Simple collider for sticking (same node name as flower_dust surface source).
const STICK_SURFACE_NODE_NAME = 'flowercenter';

const positions = new Float32Array(PARTICLE_COUNT * 3);
const velocities = new Float32Array(PARTICLE_COUNT * 3);
const spawnNorm = new Float32Array(PARTICLE_COUNT * 3);
const ageSec = new Float32Array(PARTICLE_COUNT);
const isAlive = new Uint8Array(PARTICLE_COUNT);
const baseSizes = new Float32Array(PARTICLE_COUNT);
const flickFreq = new Float32Array(PARTICLE_COUNT);
const flickFreq2 = new Float32Array(PARTICLE_COUNT);
const flickPhase = new Float32Array(PARTICLE_COUNT);
const emitterIdx = new Uint8Array(PARTICLE_COUNT);
const stuck = new Uint8Array(PARTICLE_COUNT);
const stickNorm = new Float32Array(PARTICLE_COUNT * 3);

const emitters = [];
const stickSurfaceHandles = new Set();

let particles = null;
let head = 0;
let initialized = false;

const _surfPos = new THREE.Vector3();
const _surfNorm = new THREE.Vector3();
const _cameraQuat = new THREE.Quaternion();
const _instancePos = new THREE.Vector3();
const _instanceScale = new THREE.Vector3();
const _instanceMatrix = new THREE.Matrix4();
const _blackCol = new THREE.Color(0, 0, 0);
const _rayO = new THREE.Vector3();
const _rayD = new THREE.Vector3(0, -1, 0);
const _rayDn = new THREE.Vector3();
let updateFrame = 0;
let stickSurfaceListFrame = -1;

function isStickSurfaceMeshName(name) {
    return String(name ?? '').toLowerCase().trim() === STICK_SURFACE_NODE_NAME;
}

function refreshStickSurfaceHandles(ctx) {
    stickSurfaceHandles.clear();
    const nodes = ctx.scene.listNodes?.();
    if (!nodes || !nodes.length) return;
    for (let k = 0; k < nodes.length; k++) {
        const node = nodes[k];
        if (!node?.exists || !node.isMesh) continue;
        if (!isStickSurfaceMeshName(node.name)) continue;
        if (node.handle != null) stickSurfaceHandles.add(node.handle);
    }
}

function pickStickSurfaceHit(hits) {
    if (!hits || !hits.length) return null;
    for (let h = 0; h < hits.length; h++) {
        const hi = hits[h];
        if (isStickSurfaceMeshName(hi.name)) return hi;
        if (hi.handle != null && stickSurfaceHandles.has(hi.handle)) return hi;
    }
    return null;
}

function writeStickNormalFromHit(hi, j) {
    let nx = hi.normal.x;
    let ny = hi.normal.y;
    let nz = hi.normal.z;
    const nl = Math.sqrt(nx * nx + ny * ny + nz * nz) || 1;
    stickNorm[j] = nx / nl;
    stickNorm[j + 1] = ny / nl;
    stickNorm[j + 2] = nz / nl;
}

/** Single down-ray only (cheap). */
function findStickSurfaceHit(ctx, px, py, pz) {
    _rayO.set(px, py + STICK_RAY_UP, pz);
    _rayD.set(0, -1, 0);
    return pickStickSurfaceHit(ctx.scene.raycast(_rayO, _rayD, { far: STICK_RAY_FAR }));
}

/** Re-project onto surface by casting along -surface normal. */
function snapStuckToSurface(ctx, j, px, py, pz) {
    const snx = stickNorm[j];
    const sny = stickNorm[j + 1];
    const snz = stickNorm[j + 2];
    _rayDn.set(-snx, -sny, -snz);
    if (_rayDn.lengthSq() < 1e-10) _rayDn.set(0, -1, 0);
    else _rayDn.normalize();
    const lift = STICK_NORMAL_PROBE;
    _rayO.set(px + snx * lift, py + sny * lift, pz + snz * lift);
    const rehit = pickStickSurfaceHit(ctx.scene.raycast(_rayO, _rayDn, { far: STICK_APPROACH_FAR }));
    if (!rehit) return false;
    writeStickNormalFromHit(rehit, j);
    const nnx = stickNorm[j];
    const nny = stickNorm[j + 1];
    const nnz = stickNorm[j + 2];
    positions[j] = rehit.point.x + nnx * STICK_SURFACE_EPS;
    positions[j + 1] = rehit.point.y + nny * STICK_SURFACE_EPS;
    positions[j + 2] = rehit.point.z + nnz * STICK_SURFACE_EPS;
    return true;
}

function createSoftParticleTexture(document, THREE) {
    const canvas = document.createElement('canvas');
    canvas.width = 64;
    canvas.height = 64;
    const ctx2d = canvas.getContext('2d');
    const gradient = ctx2d.createRadialGradient(32, 32, 0, 32, 32, 32);
    // Soft airy blue-white (less saturated than electric cyan).
    gradient.addColorStop(0.0, 'rgba(255,255,255,1)');
    gradient.addColorStop(0.18, 'rgba(236,244,252,1)');
    gradient.addColorStop(0.42, 'rgba(200,222,245,0.95)');
    gradient.addColorStop(0.65, 'rgba(150,190,232,0.75)');
    gradient.addColorStop(0.88, 'rgba(110,155,210,0.35)');
    gradient.addColorStop(1.0, 'rgba(70,110,170,0)');
    ctx2d.fillStyle = gradient;
    ctx2d.fillRect(0, 0, 64, 64);

    const texture = new THREE.CanvasTexture(canvas);
    texture.needsUpdate = true;
    return texture;
}

function refreshEmitters(ctx) {
    emitters.length = 0;
    for (let s = 0; s < EMITTER_SOURCES.length; s++) {
        const matches = ctx.scene.findByName(EMITTER_SOURCES[s], { exact: true });
        const node = matches[0];
        if (node && node.exists) emitters.push(node);
    }
}

function setInstanceTransform(index, position, quaternion, size) {
    _instanceScale.set(size, size, size);
    _instanceMatrix.compose(position, quaternion, _instanceScale);
    particles.setMatrixAt(index, _instanceMatrix);
}

function hideInstance(index, quaternion) {
    _instancePos.set(0, -100000, 0);
    setInstanceTransform(index, _instancePos, quaternion, HIDDEN_SCALE);
    const ic = particles?.instanceColor;
    if (ic) {
        const o = index * 3;
        ic.array[o] = 0;
        ic.array[o + 1] = 0;
        ic.array[o + 2] = 0;
    }
}

function init(ctx) {
    refreshEmitters(ctx);
    if (emitters.length === 0) return false;
    let anySurface = false;
    for (let k = 0; k < emitters.length; k++) {
        if (emitters[k].sampleSurface()) {
            anySurface = true;
            break;
        }
    }
    if (!anySurface) return false;

    for (let i = 0; i < PARTICLE_COUNT; i++) {
        isAlive[i] = 0;
        stuck[i] = 0;
        ageSec[i] = 0;
        baseSizes[i] = 0;
    }

    const texture = createSoftParticleTexture(document, THREE);
    const geometry = new THREE.PlaneGeometry(1, 1);
    const material = new THREE.MeshBasicMaterial({
        color: 0xffffff,
        map: texture,
        alphaMap: texture,
        transparent: true,
        opacity: 1,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
        side: THREE.DoubleSide,
        toneMapped: false,
    });

    particles = new THREE.InstancedMesh(geometry, material, PARTICLE_COUNT);
    particles.name = 'bee_pollen_trail';
    particles.frustumCulled = false;
    particles.instanceMatrix.setUsage(THREE.DynamicDrawUsage);
    particles.setColorAt(0, _blackCol);

    ctx.camera.raw.getWorldQuaternion(_cameraQuat);
    for (let i = 0; i < PARTICLE_COUNT; i++) {
        hideInstance(i, _cameraQuat);
    }
    particles.instanceMatrix.needsUpdate = true;
    if (particles.instanceColor) particles.instanceColor.needsUpdate = true;

    ctx.js.add(particles, { snapshotId: 'bee_pollen_trail' });
    return true;
}

function spawn(i) {
    if (emitters.length === 0) return false;
    const ei = Math.floor(Math.random() * emitters.length);
    const node = emitters[ei];
    if (!node?.exists) return false;
    const sample = node.sampleSurface({ point: _surfPos, normal: _surfNorm });
    if (!sample) return false;

    positions[i * 3] = _surfPos.x;
    positions[i * 3 + 1] = _surfPos.y;
    positions[i * 3 + 2] = _surfPos.z;

    const normalSpeed = 0.3 + Math.random() * 0.5;
    const tangentSpeed = 0.3 + Math.random() * 0.4;
    const a = Math.random() * Math.PI * 2;

    let tx, ty, tz;
    if (Math.abs(_surfNorm.y) < 0.9) {
        tx = _surfNorm.z;
        ty = 0;
        tz = -_surfNorm.x;
    } else {
        tx = 0;
        ty = -_surfNorm.z;
        tz = _surfNorm.y;
    }
    const tl = Math.sqrt(tx * tx + ty * ty + tz * tz) || 1;
    tx /= tl;
    ty /= tl;
    tz /= tl;

    const bx = _surfNorm.y * tz - _surfNorm.z * ty;
    const by = _surfNorm.z * tx - _surfNorm.x * tz;
    const bz = _surfNorm.x * ty - _surfNorm.y * tx;

    velocities[i * 3] = _surfNorm.x * normalSpeed + (Math.cos(a) * tx + Math.sin(a) * bx) * tangentSpeed;
    velocities[i * 3 + 1] = _surfNorm.y * normalSpeed + (Math.cos(a) * ty + Math.sin(a) * by) * tangentSpeed - 0.15;
    velocities[i * 3 + 2] = _surfNorm.z * normalSpeed + (Math.cos(a) * tz + Math.sin(a) * bz) * tangentSpeed;

    const j = i * 3;
    spawnNorm[j] = _surfNorm.x;
    spawnNorm[j + 1] = _surfNorm.y;
    spawnNorm[j + 2] = _surfNorm.z;

    isAlive[i] = 1;
    stuck[i] = 0;
    emitterIdx[i] = ei;
    ageSec[i] = 0;
    baseSizes[i] = 0.18 + Math.random() * 0.22;
    flickPhase[i] = Math.random() * Math.PI * 2;
    flickFreq[i] = 9 + Math.random() * 38;
    flickFreq2[i] = 2.2 + Math.random() * 11;
    return true;
}

return {
    update(ctx) {
        if (!initialized) {
            initialized = init(ctx);
            if (!initialized) return;
        }

        refreshEmitters(ctx);
        if (stickSurfaceHandles.size === 0 || updateFrame - stickSurfaceListFrame > 48) {
            refreshStickSurfaceHandles(ctx);
            stickSurfaceListFrame = updateFrame;
        }

        const dt = Math.min(ctx.clock.dt, 0.05);
        ctx.camera.raw.getWorldQuaternion(_cameraQuat);
        updateFrame++;

        let spawned = 0;
        let scan = 0;
        while (emitters.length > 0 && spawned < SPAWN_PER_FRAME && scan < PARTICLE_COUNT) {
            if (!isAlive[head] && spawn(head)) spawned++;
            head = (head + 1) % PARTICLE_COUNT;
            scan++;
        }

        const drag = Math.max(0, 1 - 0.38 * dt);
        const gravity = WORLD_GRAVITY * dt;
        const te = ctx.clock.elapsed;
        const icArr = particles.instanceColor?.array;

        let instanceColorDirty = false;

        for (let i = 0; i < PARTICLE_COUNT; i++) {
            if (!isAlive[i]) {
                stuck[i] = 0;
                hideInstance(i, _cameraQuat);
                continue;
            }

            ageSec[i] += dt;
            if (ageSec[i] >= LIFE_SECONDS) {
                isAlive[i] = 0;
                stuck[i] = 0;
                hideInstance(i, _cameraQuat);
                continue;
            }

            const u = ageSec[i] / LIFE_SECONDS;
            const fadeIn = Math.min(1, ageSec[i] / FADE_IN_SEC);
            const fadeOut = u < FADE_OUT_START
                ? 1
                : Math.max(0, 1 - (u - FADE_OUT_START) / (1 - FADE_OUT_START));
            const fade = fadeIn * fadeOut;

            const j = i * 3;

            if (stuck[i]) {
                const snx = stickNorm[j];
                const sny = stickNorm[j + 1];
                const snz = stickNorm[j + 2];

                let vx = velocities[j];
                let vy = velocities[j + 1];
                let vz = velocities[j + 2];

                let vn = vx * snx + vy * sny + vz * snz;
                vx -= snx * vn;
                vy -= sny * vn;
                vz -= snz * vn;

                const gdot = -sny;
                const tgx = -snx * gdot;
                const tgy = -1 - sny * gdot;
                const tgz = -snz * gdot;
                const gl = Math.sqrt(tgx * tgx + tgy * tgy + tgz * tgz) || 1;
                const sg = STICK_SLIDE_GRAV * dt;
                vx += (tgx / gl) * sg;
                vy += (tgy / gl) * sg;
                vz += (tgz / gl) * sg;

                const tu = TURBULENCE * 0.35 * dt;
                vx += Math.sin(te * 3.1 + flickPhase[i]) * tu;
                vz += Math.cos(te * 2.4 + i * 0.1) * tu;

                vx *= STICK_DRAG;
                vy *= STICK_DRAG;
                vz *= STICK_DRAG;

                velocities[j] = vx;
                velocities[j + 1] = vy;
                velocities[j + 2] = vz;

                positions[j] += vx * dt;
                positions[j + 1] += vy * dt;
                positions[j + 2] += vz * dt;

                if (((i + updateFrame) % STICK_SNAP_STRIDE) === 0) {
                    if (!snapStuckToSurface(ctx, j, positions[j], positions[j + 1], positions[j + 2])) {
                        stuck[i] = 0;
                    }
                } else {
                    const d = snx * vx + sny * vy + snz * vz;
                    if (d < -0.35) {
                        stuck[i] = 0;
                    }
                }
            } else {
                let nx = spawnNorm[j];
                let ny = spawnNorm[j + 1];
                let nz = spawnNorm[j + 2];

                const ei = emitterIdx[i];
                const owner = ei < emitters.length ? emitters[ei] : null;
                if (!owner || !owner.exists) {
                    isAlive[i] = 0;
                    stuck[i] = 0;
                    hideInstance(i, _cameraQuat);
                    continue;
                }

                if (((i + updateFrame) % NORM_RESAMPLE_STRIDE) === 0 && owner.sampleSurface({ point: _surfPos, normal: _surfNorm })) {
                    const a = 0.14;
                    nx = nx * (1 - a) + _surfNorm.x * a;
                    ny = ny * (1 - a) + _surfNorm.y * a;
                    nz = nz * (1 - a) + _surfNorm.z * a;
                    const nl = Math.sqrt(nx * nx + ny * ny + nz * nz) || 1;
                    nx /= nl;
                    ny /= nl;
                    nz /= nl;
                    spawnNorm[j] = nx;
                    spawnNorm[j + 1] = ny;
                    spawnNorm[j + 2] = nz;
                }

                let vx = velocities[j];
                let vy = velocities[j + 1];
                let vz = velocities[j + 2];

                const vn = vx * nx + vy * ny + vz * nz;
                const targetN = 0.12 + 0.1 * Math.sin(te * 2.2 + flickPhase[i]);
                const nk = NORMAL_FOLLOW * dt;
                vx += nx * nk * (targetN - vn);
                vy += ny * nk * (targetN - vn);
                vz += nz * nk * (targetN - vn);

                let tx;
                let ty;
                let tz;
                if (Math.abs(ny) < 0.92) {
                    tx = nz;
                    ty = 0;
                    tz = -nx;
                } else {
                    tx = 0;
                    ty = -nz;
                    tz = ny;
                }
                let tl = Math.sqrt(tx * tx + ty * ty + tz * tz) || 1;
                tx /= tl;
                ty /= tl;
                tz /= tl;
                const bx = ny * tz - nz * ty;
                const by = nz * tx - nx * tz;
                const bz = nx * ty - ny * tx;
                const swirl = 1.25 * dt * Math.sin(te * (1.4 + flickFreq2[i] * 0.08) + flickPhase[i] * 1.3);
                vx += (tx * Math.cos(te * 2.7 + i) + bx * Math.sin(te * 2.7 + i)) * swirl;
                vy += (ty * Math.cos(te * 2.7 + i) + by * Math.sin(te * 2.7 + i)) * swirl;
                vz += (tz * Math.cos(te * 2.7 + i) + bz * Math.sin(te * 2.7 + i)) * swirl;

                const lift = LIFT_ALONG_BEE_N * gravity;
                vx += nx * lift * 0.35;
                vy += ny * lift;
                vz += nz * lift * 0.35;
                vy -= gravity;

                const tu = TURBULENCE * dt;
                vx += Math.sin(te * 1.9 + i * 0.37) * tu;
                vy += Math.sin(te * 2.6 + flickPhase[i]) * tu * 0.45;
                vz += Math.cos(te * 1.7 + i * 0.21) * tu;

                vx *= drag;
                vy *= drag;
                vz *= drag;

                velocities[j] = vx;
                velocities[j + 1] = vy;
                velocities[j + 2] = vz;

                positions[j] += vx * dt;
                positions[j + 1] += vy * dt;
                positions[j + 2] += vz * dt;

                if (((i + updateFrame) % STICK_STRIDE) === 0 && vy < STICK_TRY_VY) {
                    const hit = findStickSurfaceHit(
                        ctx,
                        positions[j],
                        positions[j + 1],
                        positions[j + 2],
                    );
                    if (hit && hit.distance < STICK_RAY_FAR * 0.98) {
                        stuck[i] = 1;
                        writeStickNormalFromHit(hit, j);
                        const nnx = stickNorm[j];
                        const nny = stickNorm[j + 1];
                        const nnz = stickNorm[j + 2];
                        positions[j] = hit.point.x + nnx * STICK_SURFACE_EPS;
                        positions[j + 1] = hit.point.y + nny * STICK_SURFACE_EPS;
                        positions[j + 2] = hit.point.z + nnz * STICK_SURFACE_EPS;
                        vn = vx * nnx + vy * nny + vz * nnz;
                        vx -= nnx * vn;
                        vy -= nny * vn;
                        vz -= nnz * vn;
                        vx *= 0.55;
                        vy *= 0.55;
                        vz *= 0.55;
                        velocities[j] = vx;
                        velocities[j + 1] = vy;
                        velocities[j + 2] = vz;
                    }
                }
            }

            _instancePos.set(
                positions[i * 3],
                positions[i * 3 + 1],
                positions[i * 3 + 2],
            );
            const ph = flickPhase[i];
            const a = 0.5 + 0.5 * Math.sin(te * flickFreq[i] + ph);
            const b = 0.5 + 0.5 * Math.sin(te * flickFreq2[i] + ph * 1.713);
            const snap = ((i * 1103515245 + (te * 17.3) | 0) >>> 0) % 501;
            const c = 0.62 + 0.38 * (snap / 500);
            let glow = a * b * c;
            glow = 0.22 + glow * 0.78;
            const pulse = 0.5 + 0.5 * Math.sin(te * (3.1 + (i % 17) * 0.09) + ph * 0.37);
            glow *= 0.82 + 0.22 * pulse;
            const mult = (2.2 + glow * 3.6) * fade;
            if (icArr) {
                const o = i * 3;
                icArr[o] = mult * 0.82;
                icArr[o + 1] = mult * 0.9;
                icArr[o + 2] = mult * 0.98;
                instanceColorDirty = true;
            }

            setInstanceTransform(i, _instancePos, _cameraQuat, baseSizes[i] * fade * (0.92 + 0.08 * glow));
        }

        particles.instanceMatrix.needsUpdate = true;
        if (instanceColorDirty && particles.instanceColor) particles.instanceColor.needsUpdate = true;
    },

    dispose(ctx) {
        particles = null;
        emitters.length = 0;
        stickSurfaceHandles.clear();
        initialized = false;
        updateFrame = 0;
        stickSurfaceListFrame = -1;
    },
};
